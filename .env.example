# FCG.Users - Variáveis de ambiente para Docker Compose
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env com valores reais!

# Senha do SQL Server SA (mínimo 8 caracteres, com maiúsculas, minúsculas, números e especiais)
SA_PASSWORD=

# Chave secreta para assinatura de tokens JWT (mínimo 32 caracteres, Base64)
JWT_SECRET_KEY=

# Senha do admin do Seq (log aggregator)
SEQ_ADMIN_PASSWORD=
